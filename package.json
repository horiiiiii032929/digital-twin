{
  "name": "digital-twin",
  "private": true,
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "check": "npm run check:docs && npm run verify:evaluation-results && npm run verify:profile && npm run test:api && npm run test:web && npm run lint:web && npm run build:web",
    "check:docs": "uv run python scripts/validate_markdown_links.py",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "uv run uvicorn services.api.app.main:app --reload --port 8000",
    "test": "uv run pytest tests",
    "test:api": "uv run pytest tests",
    "verify:ingestion": "uv run python -m scripts.verify_local_ingestion",
    "verify:profile": "uv run python -m scripts.validate_component_profile",
    "verify:evaluation-results": "uv run python -m scripts.validate_evaluation_results",
    "verify:retrieval": "uv run python -m scripts.evaluate_retrieval",
    "benchmark:retrieval": "uv run --extra retrieval-benchmark python -m scripts.benchmark_retrieval --output reports/generated/retrieval-v2.json",
    "calibrate:evidence-sufficiency": "uv run --extra retrieval-benchmark python -m scripts.benchmark_evidence_sufficiency --calibration-only",
    "benchmark:evidence-sufficiency": "uv run --extra retrieval-benchmark python -m scripts.benchmark_evidence_sufficiency --output reports/generated/evidence-sufficiency-v1.json",
    "test:web": "npm --workspace apps/web run test -- --run",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint"
  }
}
